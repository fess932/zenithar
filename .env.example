# Local dev secrets. Copy to `.env` (git-ignored) and fill in — never commit `.env`.

# --- Android release signing (`make app-android-release`) ---
# Path to your keystore (the SAME zenithar.jks you base64'd into the CI secrets,
# so app updates keep one signature). Absolute, $HOME, or RELATIVE TO THE REPO
# ROOT (e.g. `zenithar.jks` or `secrets/zenithar.jks`). If you keep it inside the
# repo, make sure it's git-ignored — safest is to keep it OUTSIDE ($HOME/...).
ANDROID_KEYSTORE=$HOME/zenithar.jks
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_PASSWORD=
ANDROID_KEY_ALIAS=zenithar
