{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zenithar",
  "version": "0.1.0",
  "identifier": "com.feziv.zenithar",
  "build": {
    "frontendDist": "../landing"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Zenithar",
        "url": "index.html",
        "width": 1100,
        "height": 760,
        "minWidth": 380,
        "minHeight": 520,
        "useHttpsScheme": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [{ "scheme": ["zenithar"] }],
      "desktop": {
        "schemes": ["zenithar"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "android": {
      "minSdkVersion": 24
    },
    "macOS": {
      "entitlements": "../platforms/macos/Entitlements.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
