{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zenithar",
  "version": "0.1.0",
  "identifier": "ru.restar.zenithar",
  "build": {
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Zenithar",
        "url": "https://chat.re-star.ru",
        "width": 1100,
        "height": 760,
        "minWidth": 380,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
