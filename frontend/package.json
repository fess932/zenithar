{
  "name": "zenithar-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "dev": "bun run scripts/build.ts --watch",
    "css": "tailwindcss -i src/styles.css -o dist/styles.css --minify",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.0",
    "@types/bun": "^1.3.14",
    "bun-plugin-svelte": "^0.0.6",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@lottiefiles/dotlottie-web": "^0.75.0"
  }
}
